{
  "name": "myquro-print-agent",
  "version": "1.0.0",
  "description": "POS Print Bridge for MyQuro - Local print agent for thermal printers",
  "author": "MyQuro",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.myquro.printagent",
    "productName": "MyQuro Print Agent",
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    }
  }
}
